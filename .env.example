# Copy to `.env` and fill in. Loaded automatically by the entrypoints.

# Hugging Face token, required to download gated models (e.g. Llama-3.1-8B-Instruct).
HF_TOKEN=

# Gemini API key, required for feature interpretation and the Alpaca coherence judge.
# Erasure grids run without it; validation and final-test Alpaca scoring need it.
GEMINI_API_KEY=

# Optional: override the Hugging Face cache location (defaults to ~/.cache/huggingface).
# HF_HOME=
